# Base de données, SQLite en dev, PostgreSQL en production (voir docker-compose.yml).
DATABASE_URL="file:./dev.db"

# Auth.js, générer avec : openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-please-32chars-min"
# URL publique de l'app (pour les pages de statut, les liens d'e-mail, Auth.js)
APP_URL="http://localhost:3000"

# Protège l'endpoint de cron /api/cron/run (à appeler depuis un cron externe / Vercel Cron)
CRON_SECRET="dev-cron-secret"

# Stripe, OPTIONNEL. Sans ces clés, la facturation tourne en mode démo (plan dev).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
