// Schéma Prisma de « pulse » — SaaS de monitoring d'uptime.
// Provider sqlite pour le développement local ; le client est généré au postinstall.

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Un utilisateur authentifié. Le mot de passe est stocké haché (bcrypt).
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String
  createdAt    DateTime     @default(now())
  memberships  Membership[]
}

// Une organisation (tenant). Porte le plan de facturation et ses moniteurs.
model Organization {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  plan             String       @default("free")
  stripeCustomerId String?
  createdAt        DateTime     @default(now())
  members          Membership[]
  monitors         Monitor[]
}

// Lien N-N entre un utilisateur et une organisation, avec un rôle (RBAC).
model Membership {
  id     String       @id @default(cuid())
  userId String
  orgId  String
  role   String       @default("member")
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

// Un moniteur : une cible HTTP sondée périodiquement.
model Monitor {
  id             String       @id @default(cuid())
  orgId          String
  name           String
  url            String
  method         String       @default("GET")
  intervalSec    Int          @default(60)
  expectedStatus Int          @default(200)
  timeoutMs      Int          @default(10000)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  checks         Check[]
  incidents      Incident[]
}

// Un point de sonde (résultat d'un contrôle ponctuel).
model Check {
  id         String   @id @default(cuid())
  monitorId  String
  at         DateTime @default(now())
  ok         Boolean
  statusCode Int?
  latencyMs  Int?
  error      String?
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, at])
}

// Un incident : période d'indisponibilité d'un moniteur (résolu ou en cours).
model Incident {
  id         String    @id @default(cuid())
  monitorId  String
  startedAt  DateTime  @default(now())
  resolvedAt DateTime?
  cause      String?
  monitor    Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}
